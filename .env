# =============================================================================
# Clarify-AI — Environment Variables
# =============================================================================
# This file contains the default/shared environment configuration.
# For local overrides, use .env.local (which takes priority in Next.js).

# --- LLM Configuration ---
# OpenAI-compatible endpoint used (llama-server)
OPENAI_BASE_URL=http://localhost:8080/v1

# Model identifier — must match exactly what your provider expects
OPENAI_MODEL=

# API key — llama-server doesn't require one by default
OPENAI_API_KEY=not-needed

# --- NLI Service (Intent-Sim strategy only) ---
# DeBERTa NLI backend URL — only needed if using the Intent-Sim strategy
NLI_SERVICE_URL=http://localhost:8000